# Database (Plesk MariaDB)
# Formato: mysql://USUARIO:CONTRASEÑA@localhost:3306/NOMBRE_BD
DATABASE_URL="mysql://usuario_bd:contraseña_bd@localhost:3306/nombre_bd"

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambia-esto-por-una-clave-segura"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN="https://jipcoaching.com"

# Uploads
UPLOAD_DIR="./uploads"
