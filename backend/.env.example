# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME"

# JWT
JWT_SECRET="generate-with-openssl-rand-hex-32"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN="https://jipcoaching.com"

# Uploads
UPLOAD_DIR="./uploads"

# SMTP (Plesk mail server)
SMTP_HOST="mail.jipcoaching.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="info@jipcoaching.com"
SMTP_PASS="your-email-password"

# Email sender
FROM_EMAIL="JIP Coaching <info@jipcoaching.com>"
FRONTEND_URL="https://jipcoaching.com"
